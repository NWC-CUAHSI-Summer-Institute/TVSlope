# ------------------------------------------------------------------------------------------------
# What to commit: the three notebooks, the small input tables, and (via Git LFS) the curated
# work6 cache so `git clone` runs work6 out of the box. The heavy reference layers and the full
# staged-HAND tree are NOT committed (tens of GB) -- fetch them from the external data archive
# (see DATA.md).
# ------------------------------------------------------------------------------------------------

# --- Python / Jupyter noise ---
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store
.env

# --- large reference layers: host externally, not in git (see DATA.md) ---
data/SWORD_v17b_gpkg/
data/IRIS_2.6.gpkg
data/IRIS_3.3/
data/FIMHF_IRIS_v1.0.gpkg
data/GDW/
data/fimserv/
data/fimbench_huc8.geojson

# --- staged HAND (34 GB): commit ONLY the small files work6 needs (whitelisted below) ---
data/fimbox_out/**
!data/fimbox_out/HUC05140101/
!data/fimbox_out/HUC07130011/
!data/fimbox_out/HUC07140105/
!data/fimbox_out/HUC10170203/
!data/fimbox_out/HUC10230003/
# inside those 6 HUCs, keep only the FIM tifs, discharge inputs, and the small vector/rating files
data/fimbox_out/HUC*/watershed-data/**
!data/fimbox_out/HUC*/watershed-data/
!data/fimbox_out/HUC*/watershed-data/*_subset_streams.gpkg
!data/fimbox_out/HUC*/watershed-data/*catchments_proj_subset.gpkg
!data/fimbox_out/HUC*/watershed-data/branches/
!data/fimbox_out/HUC*/watershed-data/branches/**/
!data/fimbox_out/HUC*/watershed-data/branches/**/hydroTable_*.csv.orig
# drop the big per-branch rasters (dem/rem/hand) -- not read in cache mode
data/fimbox_out/HUC*/watershed-data/branches/**/*.tif

# --- FIMBench: keep only the 6 study events' benchmarks (large; prefer the clipped versions, see DATA.md) ---
# (Everything under data/FIMBench is ignored by default; whitelist the 6 events you push.)
data/FIMBench/**
# example whitelist lines -- uncomment/adjust for the events you commit (or push clipped copies):
# !data/FIMBench/05140101/
# !data/FIMBench/05140101/**

# --- generated outputs (regenerated by running the notebooks) ---
output/
output_exp*/
output_expA/ output_expB/ output_expC/
logs/
cache/
code/cache/
code/output/

# keep the small curated inputs
!data/slope_treatments.csv
!data/study_area_gauges.csv
